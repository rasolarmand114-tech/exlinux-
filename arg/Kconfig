# arg/Kconfig

config SCHED_ARG_KMM
	tristate "ARG Scheduler Module (Rust + ARM64 Assembly)"
	depends on SCHED_ARG
	depends on SMP
	depends on ARM64
	default m
	help
	  ARG Scheduler Layer — ۹۵٪ منطق پروژه.

	  پیاده‌سازی شده در Rust + ARM64 Assembly:
	    - Task Packing        (صرفه‌جویی انرژی)
	    - Async / Gaming mode (arg_async=1)
	    - Sync / Throughput   (arg_async=0)
	    - FPS Stability       (arg_fps=1)
	    - Energy-Aware        (arg_energy=1)
	    - Virtual Thread Layer
	    - CPU Hotplug + big.LITTLE
	    - ARM64 feature detection (LSE/FP/SVE/AES/SHA)
